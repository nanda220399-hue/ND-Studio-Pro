{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and authorization status",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "description": "User email address" },
        "displayName": { "type": "string", "description": "User display name" },
        "photoURL": { "type": "string", "description": "User profile picture URL" },
        "isApproved": { "type": "boolean", "description": "Whether the user is approved by admin" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role" },
        "apiKey": { "type": "string", "description": "User's personal Freepik API Key" },
        "lastActive": { "type": "string", "format": "date-time", "description": "Last activity timestamp" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email", "isApproved", "role"]
    },
    "GlobalStat": {
      "title": "Global Stat",
      "description": "Global statistics for the application",
      "type": "object",
      "properties": {
        "totalGenerations": { "type": "number", "description": "Total number of generations across all users" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles and their approval status"
    },
    "/stats/{statId}": {
      "schema": "GlobalStat",
      "description": "Collection for global application statistics"
    }
  }
}
