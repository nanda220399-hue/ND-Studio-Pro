// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {userId} (matches Auth UID)
// Fields:
//   - uid: string (required) - Firebase Auth UID
//   - email: string (required) - User email
//   - displayName: string - User display name
//   - photoURL: string - User profile picture
//   - isApproved: boolean (required) - Approval status
//   - role: string (required) - 'admin' or 'user'
//   - apiKey: string - Freepik API Key
//   - createdAt: timestamp - Creation time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         (request.auth.token.email == "nanda220399@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'isApproved', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.isApproved is bool &&
             data.role in ['admin', 'user'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      // Users can read their own profile. Admin can read all.
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile initially
      // Admin (hardcoded email) can bootstrap as admin/approved
      allow create: if isOwner(userId) && 
                      isValidUser(request.resource.data) &&
                      request.resource.data.uid == request.auth.uid &&
                      (
                        (request.resource.data.isApproved == false && request.resource.data.role == 'user') ||
                        (request.auth.token.email == "nanda220399@gmail.com" && request.auth.token.email_verified == true && request.resource.data.role == 'admin' && request.resource.data.isApproved == true)
                      );
      
      // Users can update their own API key. Admin can update everything.
      allow update: if isAdmin() || 
                      (isOwner(userId) && 
                       isValidUser(request.resource.data) &&
                       request.resource.data.isApproved == resource.data.isApproved &&
                       request.resource.data.role == resource.data.role &&
                       request.resource.data.email == resource.data.email &&
                       request.resource.data.uid == resource.data.uid);
      
      // Only admin can delete users
      allow delete: if isAdmin();
    }
  }
}
