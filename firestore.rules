rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    // Role check: verifies either the hardcoded admin email or the user document role
    function isAdmin() {
      return isSignedIn() && 
        (request.auth.token.email == "nanda220399@gmail.com" && request.auth.token.email_verified == true || 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'isApproved', 'role']) &&
             data.keys().size() >= 4 && data.keys().size() <= 10 &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.isApproved is bool &&
             data.role in ['admin', 'user'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 1024)) &&
             (!('apiKey' in data) || (data.apiKey is string && data.apiKey.size() <= 512)) &&
             (!('lastActive' in data) || data.lastActive is timestamp) &&
             (!('createdAt' in data) || data.createdAt is timestamp);
    }

    // --- Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin(); // Only admin can list all users
      
      allow create: if isOwner(userId) && 
                      isValidId(userId) &&
                      isValidUser(incoming()) &&
                      incoming().uid == userId &&
                      incoming().email == request.auth.token.email &&
                      (
                        // Regular user self-creation - must be unapproved by default
                        (incoming().role == 'user' && incoming().isApproved == false) ||
                        // Admin bootstrap - only for the specific email
                        (request.auth.token.email == "nanda220399@gmail.com" && isEmailVerified() && incoming().role == 'admin' && incoming().isApproved == true)
                      );

      allow update: if (isAdmin() || isOwner(userId)) && 
                      isValidUser(incoming()) &&
                      (
                        // Action: Admin updates anything (role, approval, etc)
                        (isAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['role', 'isApproved', 'apiKey', 'displayName', 'photoURL', 'lastActive'])) ||
                        
                        // Action: User updates own data (restricted fields)
                        (isOwner(userId) && 
                         incoming().role == existing().role &&
                         incoming().isApproved == existing().isApproved &&
                         incoming().uid == existing().uid &&
                         incoming().email == existing().email &&
                         incoming().diff(existing()).affectedKeys().hasOnly(['apiKey', 'displayName', 'photoURL', 'createdAt', 'lastActive']))
                      );

      allow delete: if isAdmin();
    }

    match /stats/global {
      allow read: if true;
      allow create, update: if isSignedIn() && 
                             request.resource.data.totalGenerations is number;
    }
  }
}
